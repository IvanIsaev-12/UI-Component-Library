{
	"compilerOptions": {
		"outDir": "dist",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"target": "ES2020",
		"lib": ["ES2020"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"declarationMap": true
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
