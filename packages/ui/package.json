{
	"name": "@ui-component-lib/ui",
	"version": "1.1.1",
	"type": "module",
	"description": "A modern, accessible UI component library for Next.js with 25 production-ready components built with React, TypeScript, Radix UI, and Tailwind CSS",
	"keywords": [
		"react",
		"nextjs",
		"components",
		"ui",
		"tailwind",
		"tailwindcss",
		"radix-ui",
		"typescript",
		"accessibility",
		"design-system",
		"component-library",
		"react-components",
		"next15",
		"react19",
		"app-router"
	],
	"homepage": "https://github.com/IvanIsaev-12/UI-Component-Library#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/IvanIsaev-12/UI-Component-Library.git",
		"directory": "packages/ui"
	},
	"bugs": {
		"url": "https://github.com/IvanIsaev-12/UI-Component-Library/issues"
	},
	"author": {
		"name": "Ivan Isaev",
		"email": "pochta_cheloveka@yahoo.com"
	},
	"license": "MIT",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./styles.css": "./dist/styles.css"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"provenance": "true"
	},
	"sideEffects": [
		"*.css"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@radix-ui/react-accordion": "^1.2.12",
		"@radix-ui/react-avatar": "^1.1.11",
		"@radix-ui/react-dialog": "^1.1.4",
		"@radix-ui/react-dropdown-menu": "^2.1.4",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-slot": "^1.1.1",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-tooltip": "^1.1.6",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^0.577.0",
		"tailwind-merge": "^2.6.0",
		"uuid": "^13.0.0"
	},
	"devDependencies": {
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.1.0",
		"@testing-library/user-event": "^14.5.2",
		"@types/jest-axe": "^3.5.9",
		"@types/node": "^25.5.0",
		"@types/react": "^19.0.6",
		"@ui-component-lib/eslint-config": "workspace:*",
		"@vitest/coverage-v8": "^2.1.8",
		"jest-axe": "^10.0.0",
		"jsdom": "^26.0.0",
		"react": "^19.0.0",
		"tsup": "^8.3.5",
		"typescript": "^5.7.2",
		"vitest": "^2.1.8",
		"yaml": "^2.7.0"
	},
	"peerDependencies": {
		"@types/react": "^19.0.0",
		"react": "^19.0.0"
	}
}
